#!/usr/bin/env bash
# =============================================================================
# helm-publish — Package and push Helm charts to an OCI registry
#
# Usage:
#   helm-publish                         # auto-detect chart from CWD
#   helm-publish codefresh               # explicit target (partial name ok)
#   helm-publish --pick                  # interactive multi-select
#   helm-publish --all                   # publish all discovered charts
#   helm-publish --list                  # list available charts
#   helm-publish --bump patch            # bump version before publishing
#   helm-publish --dry-run               # package only, don't push
#   helm-publish --force                 # overwrite existing version
#   helm-publish --yes                   # auto-confirm all prompts
#   helm-publish --verbose               # show full helm output
#
# Configuration:
#   Set K8_HELM_OCI_REGISTRY, K8_HELM_REGISTRY_HOST, K8_HELM_REGISTRY_USER
#   in config.env or as environment variables. GITHUB_TOKEN (or
#   K8_HELM_REGISTRY_PASSWORD) must be set for registry authentication.
#
# Chart discovery:
#   Charts are discovered from project.yaml files via helm.charts[] entries.
#   See k8-lib/bin/helm-publish-config.sh for details.
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8_LIB_DIR="${K8_LIB_DIR:-$(cd "$SCRIPT_DIR/../../k8-lib" 2>/dev/null && pwd || echo "${HOME}/.local/share/k8-lib")}"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"
export INFRA_ROOT

source "$K8_LIB_DIR/bin/common.sh"
source "$K8_LIB_DIR/bin/helm-publish-config.sh"

# =============================================================================
# FLAGS
# =============================================================================

FLAG_ALL=false
FLAG_PICK=false
FLAG_DRY_RUN=false
FLAG_VERBOSE=false
FLAG_LIST=false
FLAG_FORCE=false
BUMP_LEVEL=""
EXPLICIT_TARGET=""

usage() {
  cat <<'USAGE'
Usage: helm-publish [options] [chart-name]

Options:
  --list          List all discoverable charts with versions
  --pick          Interactive multi-select picker
  --all           Publish all discovered charts
  --dry-run       Package only, don't push to registry
  --bump LEVEL    Increment version before packaging (patch|minor|major)
  --force         Overwrite existing version in registry without confirmation
  --yes / -y      Auto-confirm all prompts
  --verbose / -v  Show full helm command output
  -h / --help     Show this help

Environment:
  GITHUB_TOKEN                Registry auth token (required for push)
  K8_HELM_OCI_REGISTRY        OCI registry URL (e.g., oci://ghcr.io/org/charts)
  K8_HELM_REGISTRY_HOST       Registry hostname (default: ghcr.io)
  K8_HELM_REGISTRY_USER       Registry username
  K8_HELM_REGISTRY_PASSWORD   Registry password (falls back to GITHUB_TOKEN)
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)        FLAG_ALL=true;     shift ;;
    --pick)       FLAG_PICK=true;    shift ;;
    --list)       FLAG_LIST=true;    shift ;;
    --dry-run)    FLAG_DRY_RUN=true; shift ;;
    --verbose|-v) FLAG_VERBOSE=true; shift ;;
    --force)      FLAG_FORCE=true;   shift ;;
    --yes|-y)     AUTO_YES=true;     shift ;;
    --bump)
      [[ $# -lt 2 ]] && die "--bump requires an argument (patch|minor|major)"
      BUMP_LEVEL="$2"
      case "$BUMP_LEVEL" in
        patch|minor|major) ;;
        *) die "Invalid bump level: $BUMP_LEVEL (must be patch, minor, or major)" ;;
      esac
      shift 2 ;;
    -h|--help)    usage; exit 0 ;;
    -*)           die "Unknown flag: $1 (see --help)" ;;
    *)
      [[ -n "$EXPLICIT_TARGET" ]] && die "Only one chart target allowed (got '$EXPLICIT_TARGET' and '$1')"
      EXPLICIT_TARGET="$1"; shift ;;
  esac
done

# =============================================================================
# VALIDATION
# =============================================================================

if [[ -z "$HELM_OCI_REGISTRY" ]]; then
  die "K8_HELM_OCI_REGISTRY is not set. Configure it in config.env or export it."
fi

if [[ -z "$HELM_REGISTRY_USER" ]]; then
  die "K8_HELM_REGISTRY_USER is not set. Configure it in config.env or export it."
fi

# =============================================================================
# TEMP DIRECTORY + CLEANUP
# =============================================================================

HELM_TMPDIR=""
_helm_cleanup() {
  [[ -n "$HELM_TMPDIR" && -d "$HELM_TMPDIR" ]] && rm -rf "$HELM_TMPDIR"
}
trap _helm_cleanup EXIT
HELM_TMPDIR="$(mktemp -d)"

# =============================================================================
# HELPERS
# =============================================================================

_helm_cmd() {
  if [[ "$FLAG_VERBOSE" == "true" ]]; then
    helm "$@"
  else
    helm "$@" 2>&1
  fi
}

# Parse selection input: "1,3,5-7" or "all"
_parse_selection() {
  local input="$1"
  local max="$2"
  local -n _out_arr="$3"
  _out_arr=()

  if [[ "$input" == "all" || "$input" == "a" ]]; then
    for ((i=1; i<=max; i++)); do
      _out_arr+=("$i")
    done
    return 0
  fi

  local token
  for token in $(echo "$input" | tr ',' ' '); do
    if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
      local lo="${BASH_REMATCH[1]}"
      local hi="${BASH_REMATCH[2]}"
      for ((i=lo; i<=hi; i++)); do
        if [[ $i -ge 1 && $i -le $max ]]; then
          _out_arr+=("$i")
        fi
      done
    elif [[ "$token" =~ ^[0-9]+$ ]]; then
      if [[ $token -ge 1 && $token -le $max ]]; then
        _out_arr+=("$token")
      fi
    fi
  done

  [[ ${#_out_arr[@]} -gt 0 ]] && return 0 || return 1
}

# =============================================================================
# LIST
# =============================================================================

_do_list() {
  _init_yaml_helm_charts

  if [[ ${#YAML_HELM_CHARTS[@]} -eq 0 ]]; then
    warn "No helm charts discovered. Add helm.charts[] entries to project.yaml files."
    exit 0
  fi

  echo ""
  printf "  ${BLU}%-30s %-12s %-12s %s${NC}\n" "CHART" "VERSION" "APP-VSN" "REGISTRY"
  printf "  %-30s %-12s %-12s %s\n" "-----" "-------" "-------" "--------"

  for key in "${YAML_HELM_CHARTS[@]}"; do
    local version app_version registry
    version="$(get_helm_chart_version "$key" 2>/dev/null || echo "?")"
    app_version="$(get_helm_chart_app_version "$key" 2>/dev/null || echo "")"
    registry="$(get_helm_registry_url "$key")"
    printf "  %-30s %-12s %-12s %s\n" "$key" "$version" "${app_version:-—}" "$registry"
  done
  echo ""
}

# =============================================================================
# PICKER
# =============================================================================

_do_pick() {
  _init_yaml_helm_charts

  if [[ ${#YAML_HELM_CHARTS[@]} -eq 0 ]]; then
    die "No helm charts discovered."
  fi

  echo ""
  echo "  ${BLU}Available Helm charts:${NC}"
  echo ""

  local idx=1
  for key in "${YAML_HELM_CHARTS[@]}"; do
    local version
    version="$(get_helm_chart_version "$key" 2>/dev/null || echo "?")"
    printf "  %3d) %-30s %s\n" "$idx" "$key" "${GRN}${version}${NC}"
    idx=$((idx + 1))
  done

  echo ""
  local answer
  read -r -p "  Select charts to publish (comma/space/range, 'all'): " answer
  echo ""

  local selected_indices
  _parse_selection "$answer" "${#YAML_HELM_CHARTS[@]}" selected_indices || die "No valid selection."

  PUBLISH_TARGETS=()
  for idx in "${selected_indices[@]}"; do
    PUBLISH_TARGETS+=("${YAML_HELM_CHARTS[$((idx - 1))]}")
  done
}

# =============================================================================
# VERSION BUMP
# =============================================================================

_bump_version() {
  local chart_path="$1"
  local level="$2"

  local current_version
  current_version="$(yq eval '.version' "$chart_path/Chart.yaml")"

  IFS='.' read -r v_major v_minor v_patch <<< "$current_version"
  v_major="${v_major:-0}"; v_minor="${v_minor:-0}"; v_patch="${v_patch:-0}"

  case "$level" in
    patch) v_patch=$((v_patch + 1)) ;;
    minor) v_minor=$((v_minor + 1)); v_patch=0 ;;
    major) v_major=$((v_major + 1)); v_minor=0; v_patch=0 ;;
  esac

  local new_version="${v_major}.${v_minor}.${v_patch}"
  yq -i ".version = \"${new_version}\"" "$chart_path/Chart.yaml"
  info "Version bumped: ${current_version} → ${GRN}${new_version}${NC}" >&2
  echo "$new_version"
}

# =============================================================================
# PUBLISH ONE CHART
# =============================================================================

PUBLISH_SUCCESSES=()
PUBLISH_FAILURES=()

publish_chart() {
  local chart_key="$1"

  local chart_path registry chart_name
  chart_path="$(get_helm_chart_path "$chart_key")"
  registry="$(get_helm_registry_url "$chart_key")"
  chart_name="$(get_helm_chart_name "$chart_key")"

  if [[ -z "$chart_path" || ! -f "$chart_path/Chart.yaml" ]]; then
    fail "Chart not found: $chart_key (expected Chart.yaml at $chart_path)"
    PUBLISH_FAILURES+=("$chart_key")
    return 1
  fi

  step "Publishing ${BLU}${chart_key}${NC}"

  # --- Bump version if requested ---
  local version
  if [[ -n "$BUMP_LEVEL" ]]; then
    version="$(_bump_version "$chart_path" "$BUMP_LEVEL")"
  else
    version="$(yq eval '.version' "$chart_path/Chart.yaml")"
  fi

  info "Chart: ${chart_name}  Version: ${GRN}${version}${NC}"
  info "Registry: ${registry}"

  # --- Check if version already exists ---
  if [[ "$FLAG_DRY_RUN" != "true" && "$FLAG_FORCE" != "true" ]]; then
    if helm show chart "${registry}/${chart_name}" --version "$version" &>/dev/null; then
      warn "Version ${version} already exists in registry."
      if ! _confirm "   Overwrite?"; then
        warn "Skipped ${chart_key} (version exists)"
        return 0
      fi
    fi
  fi

  # --- Dependency update ---
  local has_deps
  has_deps="$(yq eval '.dependencies | length // 0' "$chart_path/Chart.yaml" 2>/dev/null || echo "0")"
  if [[ "$has_deps" -gt 0 ]]; then
    info "Updating chart dependencies..."
    if ! _helm_cmd dependency update "$chart_path"; then
      fail "Dependency update failed for ${chart_key}"
      PUBLISH_FAILURES+=("$chart_key")
      return 1
    fi
    ok "Dependencies updated"
  fi

  # --- Lint ---
  info "Linting..."
  local lint_output
  if lint_output="$(helm lint "$chart_path" 2>&1)"; then
    ok "Lint passed"
  else
    fail "Lint failed for ${chart_key}:"
    echo "$lint_output" | sed 's/^/     /'
    PUBLISH_FAILURES+=("$chart_key")
    return 1
  fi

  # --- Package ---
  info "Packaging..."
  local pkg_output
  if pkg_output="$(helm package "$chart_path" --destination "$HELM_TMPDIR" 2>&1)"; then
    ok "Packaged"
  else
    fail "Package failed for ${chart_key}:"
    echo "$pkg_output" | sed 's/^/     /'
    PUBLISH_FAILURES+=("$chart_key")
    return 1
  fi

  local tgz_file="${HELM_TMPDIR}/${chart_name}-${version}.tgz"
  if [[ ! -f "$tgz_file" ]]; then
    fail "Expected package not found: $tgz_file"
    PUBLISH_FAILURES+=("$chart_key")
    return 1
  fi

  # --- Push ---
  if [[ "$FLAG_DRY_RUN" == "true" ]]; then
    ok "Dry run — skipping push"
    info "Would push: ${tgz_file} → ${registry}"
    PUBLISH_SUCCESSES+=("${chart_key}|${version}|${registry}|dry-run")
    return 0
  fi

  info "Pushing to ${registry}..."
  local push_output
  if push_output="$(_helm_cmd push "$tgz_file" "$registry" 2>&1)"; then
    ok "Published ${GRN}${chart_name}:${version}${NC} → ${registry}"
    save_helm_publish_state "$chart_key" "$version" "$registry"
    PUBLISH_SUCCESSES+=("${chart_key}|${version}|${registry}|pushed")
  else
    fail "Push failed for ${chart_key}:"
    echo "$push_output" | sed 's/^/     /'
    PUBLISH_FAILURES+=("$chart_key")
    return 1
  fi
}

# =============================================================================
# REGISTRY LOGIN
# =============================================================================

_registry_login() {
  local token="${K8_HELM_REGISTRY_PASSWORD:-$GITHUB_TOKEN}"
  if [[ -z "${token:-}" ]]; then
    die "No registry credentials. Set GITHUB_TOKEN or K8_HELM_REGISTRY_PASSWORD."
  fi

  info "Authenticating to ${HELM_REGISTRY_HOST} as ${HELM_REGISTRY_USER}..."
  if echo "$token" | helm registry login "$HELM_REGISTRY_HOST" -u "$HELM_REGISTRY_USER" --password-stdin &>/dev/null; then
    ok "Authenticated"
  else
    die "Registry login failed"
  fi
}

# =============================================================================
# MAIN
# =============================================================================

# --- List mode ---
if [[ "$FLAG_LIST" == "true" ]]; then
  _do_list
  exit 0
fi

# --- Resolve targets ---
PUBLISH_TARGETS=()

if [[ "$FLAG_ALL" == "true" ]]; then
  _init_yaml_helm_charts
  PUBLISH_TARGETS=("${YAML_HELM_CHARTS[@]}")
elif [[ "$FLAG_PICK" == "true" ]]; then
  _do_pick
elif [[ -n "$EXPLICIT_TARGET" ]]; then
  resolved="$(normalize_chart_name "$EXPLICIT_TARGET")" || exit 1
  PUBLISH_TARGETS=("$resolved")
else
  # Auto-detect from CWD
  detected="$(detect_helm_chart "$(pwd)")" && PUBLISH_TARGETS=("$detected") || {
    info "No chart detected in current directory."
    _do_pick
  }
fi

if [[ ${#PUBLISH_TARGETS[@]} -eq 0 ]]; then
  die "No charts selected."
fi

# --- Login (unless dry run) ---
if [[ "$FLAG_DRY_RUN" != "true" ]]; then
  _registry_login
fi

# --- Publish each chart ---
echo ""
info "Publishing ${#PUBLISH_TARGETS[@]} chart(s)..."

for target in "${PUBLISH_TARGETS[@]}"; do
  publish_chart "$target" || true
done

# --- Summary ---
echo ""
if [[ ${#PUBLISH_SUCCESSES[@]} -gt 0 ]]; then
  step "Published ${#PUBLISH_SUCCESSES[@]} chart(s):"
  for entry in "${PUBLISH_SUCCESSES[@]}"; do
    IFS='|' read -r key version registry status <<< "$entry"
    chart_name="${key##*/}"
    printf "  ${PASS} %-25s %-10s → %s/%s:%s" "$key" "$version" "$registry" "$chart_name" "$version"
    [[ "$status" == "dry-run" ]] && printf "  ${YEL}(dry run)${NC}"
    echo ""
  done
fi

if [[ ${#PUBLISH_FAILURES[@]} -gt 0 ]]; then
  step "${RED}Failed ${#PUBLISH_FAILURES[@]} chart(s):${NC}"
  for key in "${PUBLISH_FAILURES[@]}"; do
    echo "  ${FAIL} $key"
  done
  exit 1
fi
