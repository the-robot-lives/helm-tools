#!/usr/bin/env bash
# =============================================================================
# helm-upgrade — Dependency-ordered helm upgrade with change detection
#
# Tracks MD5 checksums of each helm chart directory. Only upgrades charts
# whose content has changed since last successful run (override with --force).
#
# Usage:
#   helm-upgrade                                          # upgrade all changed charts
#   helm-upgrade -n <namespace>                            # only one namespace
#   helm-upgrade --include backend,frontend               # whitelist
#   helm-upgrade --exclude redis                          # blacklist
#   helm-upgrade -n <namespace> --exclude redis            # combine filters
#   helm-upgrade --interactive                            # toggle selection UI
#   helm-upgrade --interactive -n <namespace>              # pre-filtered toggle UI
#   helm-upgrade --env stage                              # upgrade staging-enabled charts only
#   helm-upgrade --env stage --include frontend           # staging upgrade for specific chart
#   helm-upgrade --preview                                # show manifest diff vs live cluster
#   helm-upgrade --env stage --include frontend --preview  # preview staging diff
#   helm-upgrade --force                                  # upgrade even if unchanged
#   helm-upgrade --force-conflicts                        # auto-fix server-side apply ownership conflicts
#   helm-upgrade --dry-run                                # preview without applying
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8_LIB_DIR="${K8_LIB_DIR:-$(cd "$SCRIPT_DIR/../../k8-lib" 2>/dev/null && pwd || echo "${HOME}/.local/share/k8-lib")}"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"
STATE_DIR="$INFRA_ROOT/.helm-state"

source "$K8_LIB_DIR/bin/common.sh"
source "$K8_LIB_DIR/bin/helm-common.sh"

# =============================================================================
# MD5 checksum — deterministic hash of all files in a chart directory
#
# Used for change detection: only charts whose content has changed since
# the last successful upgrade are included (unless --force is set).
# =============================================================================

# Portable md5 pipe — uses md5sum (Linux) or md5 -q (macOS).
_md5_pipe() {
  if command -v md5sum &>/dev/null; then
    md5sum | awk '{print $1}'
  else
    md5 -q
  fi
}

# Computes a single MD5 hash over every file in a chart directory (sorted).
_chart_checksum() {
  local chart_dir="$1"
  find "$chart_dir" -type f -print0 | sort -z | xargs -0 cat 2>/dev/null | _md5_pipe
}

# Persists a chart's checksum to .helm-state/{chart}.md5 after a successful upgrade.
_save_checksum() {
  local chart="$1" checksum="$2"
  mkdir -p "$STATE_DIR"
  echo "$checksum" > "$STATE_DIR/${chart}.md5"
}

# Reads the last-known checksum for a chart. Returns empty string if none saved.
_load_checksum() {
  local chart="$1"
  local file="$STATE_DIR/${chart}.md5"
  if [[ -f "$file" ]]; then
    cat "$file"
  else
    echo ""
  fi
}

# Returns 0 (true) if a chart's current checksum differs from the saved one.
# Uses release name as the cache key so production and staging checksums
# are tracked independently (e.g. frontend vs stage-frontend).
_chart_changed() {
  local chart="$1"
  local chart_dir="$HELM_DIR/$chart"
  [[ ! -d "$chart_dir" ]] && return 1
  local key
  key="$(_get_release_name "$chart")"
  local current prev
  current="$(_chart_checksum "$chart_dir")"
  prev="$(_load_checksum "$key")"
  [[ "$current" != "$prev" ]]
}

# =============================================================================
# Parse CLI flags
# =============================================================================
FILTER_NS=""
INCLUDE_LIST=""
EXCLUDE_LIST=""
INTERACTIVE=false
FORCE=false
FORCE_CONFLICTS=false
DRY_RUN=false
PREVIEW=false

_usage() {
  cat <<'USAGE'
Usage: helm-upgrade [OPTIONS]

Options:
  -n, --namespace NS        Only charts in namespace NS
  --env ENV                 Deploy to a non-production environment (e.g. stage).
                            Only charts with a values-{ENV}.yaml overlay are included.
                            Release names are prefixed: {ENV}-{chart}.
  --include CHART[,CHART…]  Whitelist — only upgrade these charts
  --exclude CHART[,CHART…]  Blacklist — skip these charts
  --interactive, -i         Show toggle UI to select/deselect before upgrading
  --preview                 Show a diff of what would change vs the live cluster.
                            Works with --dry-run (diff only) or normal mode (diff then upgrade).
  --preview-tool TOOL       Diff viewer: code, kdiff3, opendiff, meld, terminal.
                            Default: $K8_DIFF_VIEWER or "code".
  --force                   Upgrade even if chart content hasn't changed
  --force-conflicts         Auto-fix server-side apply field ownership conflicts
  --dry-run                 Preview what would be upgraded, don't apply
  -h, --help                Show this help

Examples:
  helm-upgrade -n <namespace> --exclude redis
  helm-upgrade --include backend,frontend --force
  helm-upgrade --interactive -n <namespace>
  helm-upgrade --env stage --include frontend

See also: helm-rollback
USAGE
  echo ""
  echo "--"
  echo ""
  echo "Deployment Tiers (upgrade order: 0 → ${#TIERS[@]}):"
  for i in "${!TIERS[@]}"; do
    printf "  Tier %d:  %s\n" "$i" "${TIERS[$i]}"
  done
  echo ""
  exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--namespace)   FILTER_NS="$2"; shift 2 ;;
    --env)            ENV_NAME="$2"; shift 2 ;;
    --include)        INCLUDE_LIST="$2"; shift 2 ;;
    --exclude)        EXCLUDE_LIST="$2"; shift 2 ;;
    --interactive|-i) INTERACTIVE=true; shift ;;
    --preview)        PREVIEW=true; shift ;;
    --preview-tool)   PREVIEW=true; PREVIEW_TOOL="$2"; shift 2 ;;
    --force)          FORCE=true; shift ;;
    --force-conflicts) FORCE_CONFLICTS=true; shift ;;
    --dry-run)        DRY_RUN=true; shift ;;
    -h|--help)        _usage ;;
    *)
      _maybe_chart="$1"
      _found_in=""
      for _tier in "${TIERS[@]}"; do
        read -ra _tc <<< "$_tier"
        for _c in "${_tc[@]}"; do
          if [[ "$_c" == "$_maybe_chart" ]]; then
            _found_in="TIERS"
            break 2
          fi
        done
      done
      if [[ -z "$_found_in" && -f "$HELM_DIR/$_maybe_chart/Chart.yaml" ]]; then
        _found_in="helm/"
      fi
      if [[ -n "$_found_in" ]]; then
        echo ""
        warn "Unknown argument: $_maybe_chart"
        echo ""
        echo "  Did you mean:  helm-upgrade --include $_maybe_chart"
        echo ""
        echo "  ---"
        echo ""
        _usage 1
      else
        echo ""
        echo "  ${FAIL} Unknown argument: $1"
        echo ""
        echo "  ---"
        echo ""
        _usage 1
      fi
      ;;
  esac
done

# =============================================================================
# Discover charts and apply filters
# =============================================================================
ALL_CHARTS=()
for dir in "$HELM_DIR"/*/; do
  [[ -f "$dir/Chart.yaml" ]] || continue
  ALL_CHARTS+=("$(basename "$dir")")
done

# Validate charts against TIERS
ALL_TIER_CHARTS=()
for _tier in "${TIERS[@]}"; do
  read -ra _tier_items <<< "$_tier"
  ALL_TIER_CHARTS+=("${_tier_items[@]}")
done

for chart in "${ALL_CHARTS[@]}"; do
  if ! _in_list "$chart" "${ALL_TIER_CHARTS[@]}"; then
    warn "Chart '$chart' exists at helm/$chart/ but is not in any TIERS entry in utils/lib/helm-common.sh"
  fi
done

for chart in "${ALL_TIER_CHARTS[@]}"; do
  if ! _in_list "$chart" "${ALL_CHARTS[@]}"; then
    warn "TIERS references '$chart' but no Chart.yaml found at helm/$chart/"
  fi
done

# Validate --env value: check that at least one chart has a matching overlay
if [[ -n "$ENV_NAME" && "$ENV_NAME" != "production" ]]; then
  _env_overlays=()
  for _d in "$HELM_DIR"/*/; do
    [[ -f "$_d/values-${ENV_NAME}.yaml" ]] && _env_overlays+=("$(basename "$_d")")
  done
  if (( ${#_env_overlays[@]} == 0 )); then
    # List available environments to help with typos
    _avail_envs=()
    for _f in "$HELM_DIR"/*/values-*.yaml; do
      [[ -f "$_f" ]] || continue
      _e=$(basename "$_f" | sed 's/^values-//; s/\.yaml$//')
      _in_list "$_e" "${_avail_envs[@]+"${_avail_envs[@]}"}" || _avail_envs+=("$_e")
    done
    if (( ${#_avail_envs[@]} > 0 )); then
      die "No charts have a values-${ENV_NAME}.yaml overlay. Available environments: ${_avail_envs[*]}"
    else
      die "No charts have a values-${ENV_NAME}.yaml overlay. No environment overlays found in helm/."
    fi
  fi
fi

# Build lookup sets for include/exclude
IFS=',' read -ra INCLUDE_ARR <<< "$INCLUDE_LIST"
IFS=',' read -ra EXCLUDE_ARR <<< "$EXCLUDE_LIST"

# Warn on --include entries that don't match any known chart
if [[ -n "$INCLUDE_LIST" ]]; then
  for _inc in "${INCLUDE_ARR[@]}"; do
    if ! _in_list "$_inc" "${ALL_CHARTS[@]}"; then
      warn "--include chart '$_inc' not found in helm/"
    fi
  done
fi

CANDIDATES=()
for chart in "${ALL_CHARTS[@]}"; do
  ns="$(_get_namespace "$chart")"

  # Namespace filter
  if [[ -n "$FILTER_NS" && "$ns" != "$FILTER_NS" ]]; then
    continue
  fi

  # Environment filter — skip charts without a values-{env}.yaml overlay
  if ! _has_env_overlay "$chart"; then
    continue
  fi

  # Include whitelist
  if [[ -n "$INCLUDE_LIST" ]] && ! _in_list "$chart" "${INCLUDE_ARR[@]}"; then
    continue
  fi

  # Exclude blacklist
  if [[ -n "$EXCLUDE_LIST" ]] && _in_list "$chart" "${EXCLUDE_ARR[@]}"; then
    continue
  fi

  CANDIDATES+=("$chart")
done

if (( ${#CANDIDATES[@]} == 0 )); then
  die "No charts matched your filters (namespace=${FILTER_NS:-any}, env=${ENV_NAME:-production}, include=${INCLUDE_LIST:-all}, exclude=${EXCLUDE_LIST:-none})."
fi

# =============================================================================
# Interactive toggle UI (same pattern as docker-build --pick)
# =============================================================================
if $INTERACTIVE; then
  # Default: all candidates selected
  SELECTED=()
  for _c in "${CANDIDATES[@]}"; do
    SELECTED+=(true)
  done

  _show_list() {
    echo ""
    printf "  %-4s %-30s %-18s %s\n" "" "CHART" "NAMESPACE" "STATUS"
    printf "  %-4s %-30s %-18s %s\n" "" "─────" "─────────" "──────"
    for i in "${!CANDIDATES[@]}"; do
      local mark="[ ]"
      [[ "${SELECTED[$i]}" == "true" ]] && mark="[x]"
      local chart="${CANDIDATES[$i]}"
      local ns
      ns="$(_get_namespace "$chart")"
      local status="changed"
      if ! $FORCE && ! _chart_changed "$chart"; then
        status="unchanged"
      fi
      printf "  %s %2d) %-28s %-18s %s\n" "$mark" "$((i+1))" "$chart" "$ns" "$status"
    done
    echo ""
    echo "  Toggle by number, 'a' = all, 'n' = none, 'c' = changed-only, Enter = go, 'q' = quit"
  }

  _show_list

  while true; do
    read -r -p "  > " input
    [[ "$input" == "q" ]] && { echo "Aborted."; exit 0; }
    [[ -z "$input" ]] && break

    if [[ "$input" == "a" ]]; then
      for i in "${!SELECTED[@]}"; do SELECTED[$i]=true; done
    elif [[ "$input" == "n" ]]; then
      for i in "${!SELECTED[@]}"; do SELECTED[$i]=false; done
    elif [[ "$input" == "c" ]]; then
      for i in "${!CANDIDATES[@]}"; do
        if _chart_changed "${CANDIDATES[$i]}"; then
          SELECTED[$i]=true
        else
          SELECTED[$i]=false
        fi
      done
    elif [[ "$input" =~ ^[0-9]+$ ]] && (( input >= 1 && input <= ${#CANDIDATES[@]} )); then
      local ti=$((input - 1))
      if [[ "${SELECTED[$ti]}" == "true" ]]; then
        SELECTED[$ti]=false
      else
        SELECTED[$ti]=true
      fi
    fi

    _show_list
  done

  # Rebuild CANDIDATES from selected
  NEW_CANDIDATES=()
  for i in "${!CANDIDATES[@]}"; do
    if [[ "${SELECTED[$i]}" == "true" ]]; then
      NEW_CANDIDATES+=("${CANDIDATES[$i]}")
    fi
  done
  CANDIDATES=("${NEW_CANDIDATES[@]}")

  if (( ${#CANDIDATES[@]} == 0 )); then
    echo "No charts selected."
    exit 0
  fi
fi

# =============================================================================
# Build upgrade plan — ordered by dependency tier, skip unchanged
# =============================================================================
# Returns 0 (true) if the given chart is in the CANDIDATES array.
_in_candidates() {
  local needle="$1"
  for c in "${CANDIDATES[@]}"; do
    [[ "$c" == "$needle" ]] && return 0
  done
  return 1
}

# Ordered plan: array of "tier_index:chart" entries
PLAN=()
SKIPPED=()

for tier_idx in "${!TIERS[@]}"; do
  read -ra tier_charts <<< "${TIERS[$tier_idx]}"
  for chart in "${tier_charts[@]}"; do
    _in_candidates "$chart" || continue

    if ! $FORCE && ! _chart_changed "$chart"; then
      SKIPPED+=("$chart")
      continue
    fi

    PLAN+=("${tier_idx}:${chart}")
  done
done

# =============================================================================
# Preview
# =============================================================================
step "Helm Upgrade Plan"

if (( ${#SKIPPED[@]} > 0 )); then
  info "Unchanged (skipping): ${SKIPPED[*]}"
fi

if (( ${#PLAN[@]} == 0 )); then
  ok "All charts up to date — nothing to upgrade."
  exit 0
fi

if [[ -n "$ENV_NAME" && "$ENV_NAME" != "production" ]]; then
  info "Environment: $ENV_NAME"
fi

# Analyze change impacts for each chart in the plan
declare -A PLAN_IMPACTS
for entry in "${PLAN[@]}"; do
  chart="${entry#*:}"
  mapfile -t _impacts < <(_analyze_impacts "$chart")
  PLAN_IMPACTS["$chart"]="${_impacts[*]}"
done

# Move no-change charts from PLAN to SKIPPED (manifest-level dedup)
if ! $FORCE; then
  FILTERED_PLAN=()
  for entry in "${PLAN[@]}"; do
    chart="${entry#*:}"
    if [[ "${PLAN_IMPACTS[$chart]}" == "no-change" ]]; then
      SKIPPED+=("$chart")
    else
      FILTERED_PLAN+=("$entry")
    fi
  done
  PLAN=("${FILTERED_PLAN[@]}")
fi

echo ""
printf "  %-4s %-30s %-18s %-8s %s\n" "TIER" "RELEASE" "NAMESPACE" "TIMEOUT" "IMPACT"
printf "  %-4s %-30s %-18s %-8s %s\n" "────" "───────" "─────────" "───────" "──────"
for entry in "${PLAN[@]}"; do
  tier="${entry%%:*}"
  chart="${entry#*:}"
  release="$(_get_release_name "$chart")"
  ns="$(_get_env_namespace "$chart")"
  timeout="$(_get_timeout "$chart")"
  read -ra _imp <<< "${PLAN_IMPACTS[$chart]}"
  impact_str="$(_format_impacts "${_imp[@]}")"
  printf "  %-4s %-30s %-18s %-8s " "$tier" "$release" "$ns" "$timeout"
  echo -e "$impact_str"
done
echo ""
echo "  ${#PLAN[@]} chart(s) to upgrade, ${#SKIPPED[@]} unchanged"
echo ""

# Run preview if requested — shows diff for each chart in the plan
if $PREVIEW; then
  for entry in "${PLAN[@]}"; do
    chart="${entry#*:}"
    _preview_chart "$chart"
  done
fi

if $DRY_RUN; then
  info "Dry run — no changes applied."
  exit 0
fi

# =============================================================================
# Confirm before executing
# =============================================================================
read -r -p "  Proceed with upgrade? [y/n]: " answer </dev/tty
case "$answer" in
  y|Y|yes) ;;
  *)       echo "Aborted."; exit 0 ;;
esac

# =============================================================================
# Execute upgrades tier-by-tier
# =============================================================================
SUCCEEDED=()
FAILED=()
FAILED_NAMES=()

# Detects server-side apply field ownership conflicts in helm output.
_is_conflict_error() {
  grep -q 'conflict.*using\|conflicts with' <<< "$1"
}

# Attempts to resolve server-side apply ownership conflicts by re-applying
# each matching resource with --field-manager=helm --force-conflicts.
# Returns 0 (true) if at least one resource was fixed.
_fix_field_ownership() {
  local chart="$1" ns="$2"
  local resource_types=("deployment" "statefulset" "daemonset" "service" "configmap")
  local fixed=false

  for rtype in "${resource_types[@]}"; do
    local resources
    resources=$(kubectl get "$rtype" -n "$ns" -l "app.kubernetes.io/instance=$chart" -o name 2>/dev/null || true)
    if [[ -z "$resources" ]]; then
      resources=$(kubectl get "$rtype" -n "$ns" -l "app=$chart" -o name 2>/dev/null || true)
    fi
    for res in $resources; do
      [[ -z "$res" ]] && continue
      if kubectl get "$res" -n "$ns" -o yaml \
           | kubectl apply --server-side --field-manager='helm' --force-conflicts -f - &>/dev/null; then
        info "  Transferred ownership: $res"
        fixed=true
      fi
    done
  done

  $fixed
}

_run_upgrade() {
  local chart="$1"
  local release ns timeout chart_dir
  release="$(_get_release_name "$chart")"
  ns="$(_get_env_namespace "$chart")"
  timeout="$(_get_timeout "$chart")"
  chart_dir="$HELM_DIR/$chart"

  # Check upgrade policy — prompt if impacts require confirmation
  read -ra _imp <<< "${PLAN_IMPACTS[$chart]:-}"
  if (( ${#_imp[@]} > 0 )) && _policy_requires_prompt "$chart" "${_imp[@]}"; then
    local impact_str
    impact_str="$(_format_impacts "${_imp[@]}")"
    echo ""
    echo -e "  ${WARN} $release requires confirmation — impacts: $impact_str"
    read -r -p "  Apply this upgrade? [y/n]: " _answer </dev/tty
    case "$_answer" in
      y|Y|yes) ;;
      *)
        info "Skipped $release (user declined)"
        SKIPPED+=("$release")
        return 0
        ;;
    esac
  fi

  step "Upgrading $release → namespace=$ns timeout=$timeout"

  local helm_cmd=(helm upgrade --install "$release" "$chart_dir"
       --namespace "$ns" --create-namespace
       --wait --timeout "$timeout")
  local _vfiles
  mapfile -t _vfiles < <(_get_values_files "$chart")
  for f in "${_vfiles[@]}"; do
    helm_cmd+=(-f "$f")
  done

  local helm_output
  if helm_output=$("${helm_cmd[@]}" 2>&1); then
    [[ -n "$helm_output" ]] && echo "$helm_output"
    ok "$release upgraded successfully"
    local checksum
    checksum="$(_chart_checksum "$chart_dir")"
    _save_checksum "$release" "$checksum"
    SUCCEEDED+=("$release")
    return 0
  fi

  if _is_conflict_error "$helm_output"; then
    if $FORCE_CONFLICTS; then
      warn "$release hit field ownership conflict — --force-conflicts is set, fixing automatically"
    else
      warn "$release hit field ownership conflict — attempting auto-fix"
      warn "  (use --force-conflicts to skip this prompt in future)"
    fi

    echo "$helm_output" | grep -E 'conflicts with|conflict.*using' | head -5 | while IFS= read -r line; do
      info "  $line"
    done

    if _fix_field_ownership "$release" "$ns"; then
      info "Field ownership transferred to helm — retrying upgrade"
      if helm_output=$("${helm_cmd[@]}" 2>&1); then
        [[ -n "$helm_output" ]] && echo "$helm_output"
        ok "$release upgraded successfully (after conflict fix)"
        local checksum
        checksum="$(_chart_checksum "$chart_dir")"
        _save_checksum "$release" "$checksum"
        SUCCEEDED+=("$release")
        return 0
      else
        echo "$helm_output"
      fi
    else
      warn "Could not auto-fix ownership — no matching resources found"
    fi
  fi

  echo "$helm_output"
  fail "$release upgrade FAILED"
  FAILED+=("$release")
  FAILED_NAMES+=("$release")
  return 1
}

CURRENT_TIER=-1
TIER_FAILED=false

for entry in "${PLAN[@]}"; do
  tier="${entry%%:*}"
  chart="${entry#*:}"

  # New tier boundary — check if previous tier had failures
  if [[ "$tier" != "$CURRENT_TIER" ]]; then
    if $TIER_FAILED; then
      warn "Tier $CURRENT_TIER had failures — skipping remaining tiers"
      # Move remaining plan entries to failed
      for remaining in "${PLAN[@]}"; do
        rtier="${remaining%%:*}"
        rchart="${remaining#*:}"
        if (( rtier > CURRENT_TIER )); then
          (( ${#FAILED_NAMES[@]} )) && _in_list "$rchart" "${FAILED_NAMES[@]}" && continue
          (( ${#SUCCEEDED[@]} )) && _in_list "$rchart" "${SUCCEEDED[@]}" && continue
          FAILED+=("$rchart (skipped — upstream tier failed)")
        fi
      done
      break
    fi
    CURRENT_TIER="$tier"
    TIER_FAILED=false
  fi

  _run_upgrade "$chart" || TIER_FAILED=true
done

# =============================================================================
# Summary
# =============================================================================
echo ""
echo "========================================"
echo "  Helm Upgrade Summary"
echo "========================================"
if (( ${#SUCCEEDED[@]} )); then
  for s in "${SUCCEEDED[@]}"; do
    echo "  ${PASS} $s"
  done
fi
if (( ${#FAILED[@]} )); then
  for f in "${FAILED[@]}"; do
    echo "  ${FAIL} $f"
  done
fi
if (( ${#SKIPPED[@]} )); then
  for s in "${SKIPPED[@]}"; do
    echo "  ── $s (unchanged)"
  done
fi
echo "========================================"
echo "  ${#SUCCEEDED[@]} succeeded, ${#FAILED[@]} failed, ${#SKIPPED[@]} unchanged"
echo "========================================"

(( ${#FAILED[@]} > 0 )) && exit 1
exit 0
