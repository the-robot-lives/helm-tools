#!/usr/bin/env bash
# =============================================================================
# helm-rollback — Dependency-aware rollback with revision selection
#
# Rolls back helm releases in REVERSE tier order (app-layer first, infra last).
#
# Usage:
#   helm-rollback                                        # auto-detect unhealthy/recent deploys
#   helm-rollback --include backend,frontend              # rollback specific charts
#   helm-rollback --env stage --include frontend         # rollback staging release
#   helm-rollback --back-to 15m                          # undo deploys from last 15 minutes
#   helm-rollback --back-to 1h --dry-run                 # preview time-based rollback
#   helm-rollback -n <namespace> --exclude redis          # filter by namespace
# =============================================================================
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
K8_LIB_DIR="${K8_LIB_DIR:-$(cd "$SCRIPT_DIR/../../k8-lib" 2>/dev/null && pwd || echo "${HOME}/.local/share/k8-lib")}"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"

# Pre-parse --config (must resolve before k8-lib sourcing)
for _k8_arg in "$@"; do
  case "$_k8_arg" in
    --config=*) export K8_CONFIG="${_k8_arg#--config=}" ;;
  esac
done
_k8_prev=""
for _k8_arg in "$@"; do
  [[ "$_k8_prev" == "--config" ]] && export K8_CONFIG="$_k8_arg"
  _k8_prev="$_k8_arg"
done
unset _k8_arg _k8_prev

source "$K8_LIB_DIR/bin/common.sh"
source "$K8_LIB_DIR/bin/helm-common.sh"

# =============================================================================
# Prerequisites
# =============================================================================
for cmd in helm kubectl jq; do
  command -v "$cmd" &>/dev/null || die "$cmd is required but not found"
done

# =============================================================================
# Parse CLI flags
# =============================================================================
FILTER_NS=""
INCLUDE_LIST=""
EXCLUDE_LIST=""
BACK_TO=""
DRY_RUN=false
FORCE=false
PREVIEW=false

_usage() {
  cat <<'USAGE'
Usage: helm-rollback [OPTIONS]

Modes:
  (no flags)                    Auto-detect unhealthy pods & recent deploys
  --include CHART[,CHART…]      Rollback specific charts (interactive revision pick)
  --back-to DURATION            Undo all deploys after now - DURATION (e.g. 15m, 1h, 2h30m)

Options:
  -n, --namespace NS            Only charts in namespace NS
  --env ENV                     Target a non-production environment (e.g. stage).
                                Uses {ENV}-{chart} release names and env namespace.
  --exclude CHART[,CHART…]      Skip these charts
  --preview                     Show manifest diff before rollback
  --preview-tool TOOL           Diff viewer: code, kdiff3, opendiff, meld, terminal.
                                Default: $K8_DIFF_VIEWER or "code".
  --dry-run                     Preview rollback plan without executing
  --force                       Skip confirmation prompt
  --config PATH                 Use alternate k8-lib config file
  -h, --help                    Show this help

Examples:
  helm-rollback --include backend,frontend
  helm-rollback --env stage --include frontend
  helm-rollback --back-to 30m
  helm-rollback --back-to 1h --dry-run
  helm-rollback -n <namespace>

See also: helm-upgrade
USAGE
  echo ""
  echo "--"
  echo ""
  echo "Deployment Tiers (rollback order: $((${#TIERS[@]} - 1)) → 0):"
  for i in "${!TIERS[@]}"; do
    printf "  Tier %d:  %s\n" "$i" "${TIERS[$i]}"
  done
  echo ""
  exit "${1:-0}"
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -n|--namespace)   FILTER_NS="$2"; shift 2 ;;
    --env)            ENV_NAME="$2"; shift 2 ;;
    --include)        INCLUDE_LIST="$2"; shift 2 ;;
    --exclude)        EXCLUDE_LIST="$2"; shift 2 ;;
    --back-to)        BACK_TO="$2"; shift 2 ;;
    --preview)        PREVIEW=true; shift ;;
    --preview-tool)   PREVIEW=true; PREVIEW_TOOL="$2"; shift 2 ;;
    --config)         shift 2; continue ;;
    --config=*)       shift; continue ;;
    --dry-run)        DRY_RUN=true; shift ;;
    --force)          FORCE=true; shift ;;
    -h|--help)        _usage ;;
    *)
      _maybe_chart="$1"
      _found_in=""
      for _tier in "${TIERS[@]}"; do
        read -ra _tc <<< "$_tier"
        for _c in "${_tc[@]}"; do
          if [[ "$_c" == "$_maybe_chart" ]]; then
            _found_in="TIERS"
            break 2
          fi
        done
      done
      if [[ -z "$_found_in" && -f "$HELM_DIR/$_maybe_chart/Chart.yaml" ]]; then
        _found_in="helm/"
      fi
      if [[ -n "$_found_in" ]]; then
        echo ""
        warn "Unknown argument: $_maybe_chart"
        echo ""
        echo "  Did you mean:  helm-rollback --include $_maybe_chart"
        echo ""
        echo "  ---"
        echo ""
        _usage 1
      else
        echo ""
        echo "  ${FAIL} Unknown argument: $1"
        echo ""
        echo "  ---"
        echo ""
        _usage 1
      fi
      ;;
  esac
done

# =============================================================================
# Helper functions
# =============================================================================

# Emits all charts that pass namespace/exclude/env filters.
# When --env is set, only charts with a matching overlay are included.
_get_all_known_charts() {
  IFS=',' read -ra _excl <<< "$EXCLUDE_LIST"
  for tier_idx in "${!TIERS[@]}"; do
    read -ra tier_charts <<< "${TIERS[$tier_idx]}"
    for chart in "${tier_charts[@]}"; do
      local ns
      ns="$(_get_env_namespace "$chart")"
      [[ -n "$FILTER_NS" && "$ns" != "$FILTER_NS" ]] && continue
      [[ -n "$EXCLUDE_LIST" ]] && _in_list "$chart" "${_excl[@]}" && continue
      _has_env_overlay "$chart" || continue
      echo "$chart"
    done
  done
}

# Fetches helm release history as JSON. Uses the env-aware release name
# so staging releases (e.g. stage-frontend) are queried correctly.
_get_helm_history() {
  local chart="$1" ns="$2"
  local release
  release="$(_get_release_name "$chart")"
  helm history "$release" -n "$ns" --output json 2>/dev/null || echo "[]"
}

# Parses a human-friendly duration string (e.g. "15m", "2h30m") into seconds.
_parse_duration() {
  local input="$1"
  local total=0
  local remaining="$input"

  while [[ -n "$remaining" ]]; do
    if [[ "$remaining" =~ ^([0-9]+)h(.*)$ ]]; then
      total=$(( total + ${BASH_REMATCH[1]} * 3600 ))
      remaining="${BASH_REMATCH[2]}"
    elif [[ "$remaining" =~ ^([0-9]+)m(.*)$ ]]; then
      total=$(( total + ${BASH_REMATCH[1]} * 60 ))
      remaining="${BASH_REMATCH[2]}"
    elif [[ "$remaining" =~ ^([0-9]+)s(.*)$ ]]; then
      total=$(( total + ${BASH_REMATCH[1]} ))
      remaining="${BASH_REMATCH[2]}"
    else
      die "Invalid duration format: $input (use e.g. 15m, 1h, 2h30m)"
    fi
  done

  echo "$total"
}

# Converts a helm history date string to epoch seconds. Handles both GNU
# date (Linux) and BSD date (macOS) formats.
_parse_helm_date() {
  local date_str="$1"
  if date --version &>/dev/null 2>&1; then
    date -d "$date_str" +%s 2>/dev/null || echo "0"
  else
    date -j -f "%Y-%m-%d %H:%M:%S" "$date_str" +%s 2>/dev/null \
      || date -j -f "%Y-%m-%dT%H:%M:%S" "$date_str" +%s 2>/dev/null \
      || echo "0"
  fi
}

# Prints a formatted table of helm revision history for interactive selection.
# Shows revision number, status, chart version, app version, date, and description.
_format_revision_table() {
  local chart="$1" json="$2"
  local count
  count=$(echo "$json" | jq 'length')

  echo ""
  printf "  ${BLU}%s${NC} — revision history:\n" "$chart"
  printf "  %-5s %-12s %-22s %-12s %-20s %s\n" "REV" "STATUS" "CHART" "APP-VSN" "DATE" "DESCRIPTION"
  printf "  %-5s %-12s %-22s %-12s %-20s %s\n" "───" "──────" "─────" "───────" "────" "───────────"

  for (( i=count-1; i>=0; i-- )); do
    local rev status chart_vsn app_vsn updated desc
    rev=$(echo "$json" | jq -r ".[$i].revision")
    status=$(echo "$json" | jq -r ".[$i].status")
    chart_vsn=$(echo "$json" | jq -r ".[$i].chart")
    app_vsn=$(echo "$json" | jq -r ".[$i].app_version")
    updated=$(echo "$json" | jq -r ".[$i].updated" | sed 's/\.[0-9]* / /' | cut -c1-19)
    desc=$(echo "$json" | jq -r ".[$i].description" | cut -c1-30)

    [[ "$status" != "deployed" && "$status" != "superseded" ]] && continue

    local status_color="$NC"
    [[ "$status" == "deployed" ]] && status_color="$GRN"

    printf "  %-5s ${status_color}%-12s${NC} %-22s %-12s %-20s %s\n" \
      "$rev" "$status" "$chart_vsn" "$app_vsn" "$updated" "$desc"
  done
  echo ""
}

# Interactive prompt: displays revision history and asks the user to pick a
# target revision number. Returns the selected revision via stdout; the
# table is printed to stderr so it doesn't pollute the return value.
_select_revision() {
  local chart="$1" ns="$2"
  local json
  json="$(_get_helm_history "$chart" "$ns")"

  local count
  count=$(echo "$json" | jq 'length')

  if (( count < 2 )); then
    warn "Only one revision exists for $chart — cannot rollback" >&2
    return 1
  fi

  _format_revision_table "$chart" "$json" >&2

  local valid_revs=()
  for (( i=count-1; i>=0; i-- )); do
    local status
    status=$(echo "$json" | jq -r ".[$i].status")
    [[ "$status" == "deployed" || "$status" == "superseded" ]] || continue
    valid_revs+=("$(echo "$json" | jq -r ".[$i].revision")")
  done

  # Find last stable (most recent superseded) revision for default
  local last_stable=""
  for (( i=count-1; i>=0; i-- )); do
    local status
    status=$(echo "$json" | jq -r ".[$i].status")
    if [[ "$status" == "superseded" ]]; then
      last_stable=$(echo "$json" | jq -r ".[$i].revision")
      break
    fi
  done

  while true; do
    local prompt_hint=""
    [[ -n "$last_stable" ]] && prompt_hint=" [0 = last stable (rev $last_stable)]"
    read -r -p "  Select target revision for $chart (revision number$prompt_hint): " input </dev/tty
    # Default / 0 → pick last stable (most recent superseded)
    if [[ -z "$input" || "$input" == "0" ]]; then
      if [[ -n "$last_stable" ]]; then
        echo "$last_stable"
        return 0
      else
        warn "No superseded (stable) revision found — enter a specific revision number." >&2
        continue
      fi
    fi
    if [[ "$input" =~ ^[0-9]+$ ]] && _in_list "$input" "${valid_revs[@]}"; then
      echo "$input"
      return 0
    fi
    warn "Invalid selection. Enter a revision number from the list above." >&2
  done
}

# Extracts the currently deployed revision number from helm history JSON.
_get_current_revision() {
  local json="$1"
  echo "$json" | jq -r '[.[] | select(.status == "deployed")] | last | .revision // empty'
}

# Returns 0 (true) if any pod matching the chart's labels is NOT fully ready.
# Tries three label selectors in order: instance, app, name.
_check_pod_health() {
  local chart="$1" ns="$2"
  local pods
  pods=$(kubectl get pods -n "$ns" -l "app.kubernetes.io/instance=$chart" --no-headers 2>/dev/null)
  if [[ -z "$pods" ]]; then
    pods=$(kubectl get pods -n "$ns" -l "app=$chart" --no-headers 2>/dev/null)
  fi
  if [[ -z "$pods" ]]; then
    pods=$(kubectl get pods -n "$ns" -l "app.kubernetes.io/name=$chart" --no-headers 2>/dev/null)
  fi
  [[ -z "$pods" ]] && return 1

  echo "$pods" | grep -qvE '\s([0-9]+)/\1\s+Running'
}

# Returns the TIERS index for a chart. Used to sort rollback plans by
# reverse dependency order (app-layer first, infra last).
_get_tier_for_chart() {
  local target="$1"
  for tier_idx in "${!TIERS[@]}"; do
    read -ra tier_charts <<< "${TIERS[$tier_idx]}"
    for chart in "${tier_charts[@]}"; do
      [[ "$chart" == "$target" ]] && echo "$tier_idx" && return
    done
  done
  echo "-1"
}

# =============================================================================
# Rollback plan storage — parallel arrays (bash lacks structs)
#
# Each index i represents one rollback action:
#   PLAN_CHARTS[i]       — chart name (e.g. frontend)
#   PLAN_NS[i]           — target namespace
#   PLAN_REVISION[i]     — target revision to roll back to
#   PLAN_TIER[i]         — dependency tier index (for ordering)
#   PLAN_DATE[i]         — date of the target revision (for display)
#   PLAN_CURRENT_REV[i]  — currently deployed revision (for display)
# =============================================================================
PLAN_CHARTS=()
PLAN_NS=()
PLAN_REVISION=()
PLAN_TIER=()
PLAN_DATE=()
PLAN_CURRENT_REV=()

# Appends a chart to the rollback plan arrays.
_add_to_plan() {
  local chart="$1" ns="$2" revision="$3" tier="$4" date="${5:-}" current_rev="${6:-}"
  PLAN_CHARTS+=("$chart")
  PLAN_NS+=("$ns")
  PLAN_REVISION+=("$revision")
  PLAN_TIER+=("$tier")
  PLAN_DATE+=("$date")
  PLAN_CURRENT_REV+=("$current_rev")
}

# Removes a chart from the rollback plan by rebuilding the arrays without it.
_remove_from_plan() {
  local target="$1"
  local new_charts=() new_ns=() new_rev=() new_tier=() new_date=() new_current=()
  for i in "${!PLAN_CHARTS[@]}"; do
    if [[ "${PLAN_CHARTS[$i]}" != "$target" ]]; then
      new_charts+=("${PLAN_CHARTS[$i]}")
      new_ns+=("${PLAN_NS[$i]}")
      new_rev+=("${PLAN_REVISION[$i]}")
      new_tier+=("${PLAN_TIER[$i]}")
      new_date+=("${PLAN_DATE[$i]}")
      new_current+=("${PLAN_CURRENT_REV[$i]}")
    fi
  done
  PLAN_CHARTS=("${new_charts[@]+"${new_charts[@]}"}")
  PLAN_NS=("${new_ns[@]+"${new_ns[@]}"}")
  PLAN_REVISION=("${new_rev[@]+"${new_rev[@]}"}")
  PLAN_TIER=("${new_tier[@]+"${new_tier[@]}"}")
  PLAN_DATE=("${new_date[@]+"${new_date[@]}"}")
  PLAN_CURRENT_REV=("${new_current[@]+"${new_current[@]}"}")
}

# Prints the rollback plan as a formatted table, sorted by tier descending
# (highest tier = app layer rolled back first).
_display_rollback_plan() {
  echo ""
  step "Rollback Plan (execution order: tier 8 → 0)"
  echo ""
  printf "  %-4s %-30s %-12s %-8s %-8s %-20s\n" "TIER" "CHART" "NAMESPACE" "CUR" "TARGET" "TARGET-DATE"
  printf "  %-4s %-30s %-12s %-8s %-8s %-20s\n" "────" "─────" "─────────" "───" "──────" "───────────"

  # Sort by tier descending for display
  local indices=()
  for i in "${!PLAN_CHARTS[@]}"; do indices+=("$i"); done

  # Simple bubble sort by tier descending
  local n=${#indices[@]}
  for (( a=0; a<n; a++ )); do
    for (( b=a+1; b<n; b++ )); do
      if (( PLAN_TIER[indices[a]] < PLAN_TIER[indices[b]] )); then
        local tmp="${indices[$a]}"
        indices[$a]="${indices[$b]}"
        indices[$b]="$tmp"
      fi
    done
  done

  for i in "${indices[@]}"; do
    printf "  %-4s %-30s %-12s %-8s %-8s %-20s\n" \
      "${PLAN_TIER[$i]}" "${PLAN_CHARTS[$i]}" "${PLAN_NS[$i]}" \
      "${PLAN_CURRENT_REV[$i]}" "${PLAN_REVISION[$i]}" "${PLAN_DATE[$i]}"
  done
  echo ""
  echo "  ${#PLAN_CHARTS[@]} chart(s) to rollback"
  echo ""
}

# Prompts the user to confirm, abort, or edit the rollback plan.
# Returns 0 = proceed, 1 = abort, 2 = edit.
_confirm_plan() {
  if $DRY_RUN || $FORCE; then return 0; fi
  read -r -p "  Proceed with rollback? [y/n/edit]: " answer
  case "$answer" in
    y|Y|yes) return 0 ;;
    edit|e)  return 2 ;;
    *)       return 1 ;;
  esac
}

# Interactive plan editor: lets the user change target revisions ("edit <chart>")
# or remove charts ("rm <chart>") before executing. Loops until "done" or confirm.
_edit_rollback_plan() {
  while true; do
    echo ""
    echo "  Commands:  edit <chart>  |  rm <chart>  |  done"
    read -r -p "  > " input

    if [[ -z "$input" || "$input" == "done" ]]; then
      _display_rollback_plan
      if $FORCE; then return 0; fi
      read -r -p "  Proceed with rollback? [y/n/edit]: " answer
      case "$answer" in
        y|Y|yes) return 0 ;;
        edit|e)  continue ;;
        *)       return 1 ;;
      esac
    elif [[ "$input" == rm\ * ]]; then
      local target="${input#rm }"
      target="${target## }"
      local found=false
      for i in "${!PLAN_CHARTS[@]}"; do
        if [[ "${PLAN_CHARTS[$i]}" == "$target" ]]; then
          found=true
          break
        fi
      done
      if $found; then
        _remove_from_plan "$target"
        ok "Removed $target from plan"
        if (( ${#PLAN_CHARTS[@]} == 0 )); then
          info "Plan is empty. Nothing to rollback."
          return 1
        fi
      else
        warn "Chart '$target' not in plan"
      fi
    elif [[ "$input" == edit\ * ]]; then
      local target="${input#edit }"
      target="${target## }"
      local found=false
      local target_ns=""
      for i in "${!PLAN_CHARTS[@]}"; do
        if [[ "${PLAN_CHARTS[$i]}" == "$target" ]]; then
          found=true
          target_ns="${PLAN_NS[$i]}"
          break
        fi
      done
      if $found; then
        local new_rev
        if new_rev=$(_select_revision "$target" "$target_ns"); then
          _remove_from_plan "$target"
          local tier
          tier="$(_get_tier_for_chart "$target")"
          local json
          json="$(_get_helm_history "$target" "$target_ns")"
          local date
          date=$(echo "$json" | jq -r ".[] | select(.revision == $new_rev) | .updated" | sed 's/\.[0-9]* / /' | cut -c1-19)
          local current_rev
          current_rev="$(_get_current_revision "$json")"
          _add_to_plan "$target" "$target_ns" "$new_rev" "$tier" "$date" "$current_rev"
          ok "Updated $target → revision $new_rev"
        fi
      else
        warn "Chart '$target' not in plan"
      fi
    else
      warn "Unknown command. Use: edit <chart>, rm <chart>, or done"
    fi
  done
}

# =============================================================================
# Execution engine — reverse tier order
#
# Walks tiers from highest (app layer) to lowest (infra), rolling back each
# chart in the plan. Collects succeeded/failed for the summary.
# =============================================================================
# Diffs the current deployed manifest against the target revision's manifest.
# Uses `helm get manifest --revision` to fetch both sides.
_preview_rollback_chart() {
  local chart="$1" ns="$2" current_rev="$3" target_rev="$4"
  local release
  release="$(_get_release_name "$chart")"

  step "Preview rollback: $release rev $current_rev → $target_rev"

  local tmpdir
  tmpdir=$(mktemp -d)
  local current_file="$tmpdir/${release}.rev${current_rev}.yaml"
  local target_file="$tmpdir/${release}.rev${target_rev}.yaml"

  helm get manifest "$release" -n "$ns" --revision "$current_rev" 2>/dev/null \
    | sed '/^$/d' > "$current_file" || true
  helm get manifest "$release" -n "$ns" --revision "$target_rev" 2>/dev/null \
    | sed '/^$/d' > "$target_file" || true

  if diff -q "$current_file" "$target_file" &>/dev/null; then
    ok "$release: rev $current_rev and rev $target_rev are identical"
    rm -rf "$tmpdir"
    return 0
  fi

  info "Opening diff: rev $current_rev → rev $target_rev"
  _open_diff_viewer "$current_file" "$target_file" "$release"

  rm -rf "$tmpdir"
  echo ""
}

_execute_rollback() {
  # Show preview diffs before executing if --preview is set
  if $PREVIEW; then
    for i in "${!PLAN_CHARTS[@]}"; do
      _preview_rollback_chart \
        "${PLAN_CHARTS[$i]}" "${PLAN_NS[$i]}" \
        "${PLAN_CURRENT_REV[$i]}" "${PLAN_REVISION[$i]}"
    done
  fi

  if $DRY_RUN; then
    info "Dry run — no changes applied."
    return 0
  fi

  local SUCCEEDED=()
  local FAILED=()

  # Execute in reverse tier order
  for (( tier_idx=${#TIERS[@]}-1; tier_idx>=0; tier_idx-- )); do
    read -ra tier_charts <<< "${TIERS[$tier_idx]}"
    for chart in "${tier_charts[@]}"; do
      # Check if chart is in plan
      local plan_idx=-1
      for i in "${!PLAN_CHARTS[@]}"; do
        if [[ "${PLAN_CHARTS[$i]}" == "$chart" ]]; then
          plan_idx=$i
          break
        fi
      done
      (( plan_idx < 0 )) && continue

      local ns="${PLAN_NS[$plan_idx]}"
      local revision="${PLAN_REVISION[$plan_idx]}"
      local release timeout
      release="$(_get_release_name "$chart")"
      timeout="$(_get_timeout "$chart")"

      step "Rolling back $release → revision $revision (ns=$ns, timeout=$timeout)"

      local output
      if output=$(helm rollback "$release" "$revision" -n "$ns" \
           --wait --timeout "$timeout" 2>&1); then
        [[ -n "$output" ]] && echo "$output"
        ok "$release rolled back to revision $revision"
        SUCCEEDED+=("$release")
      else
        echo "$output"
        fail "$release rollback FAILED"
        FAILED+=("$release")
      fi
    done
  done

  # Summary
  echo ""
  echo "========================================"
  echo "  Helm Rollback Summary"
  echo "========================================"
  if (( ${#SUCCEEDED[@]} )); then
    for s in "${SUCCEEDED[@]}"; do
      echo "  ${PASS} $s"
    done
  fi
  if (( ${#FAILED[@]} )); then
    for f in "${FAILED[@]}"; do
      echo "  ${FAIL} $f"
    done
  fi
  echo "========================================"
  echo "  ${#SUCCEEDED[@]} succeeded, ${#FAILED[@]} failed"
  echo "========================================"

  (( ${#FAILED[@]} > 0 )) && return 1
  return 0
}

# =============================================================================
# Mode 1: --include (explicit chart selection)
# =============================================================================
_mode_include() {
  IFS=',' read -ra charts <<< "$INCLUDE_LIST"
  IFS=',' read -ra _excl <<< "$EXCLUDE_LIST"

  for chart in "${charts[@]}"; do
    [[ -n "$EXCLUDE_LIST" ]] && _in_list "$chart" "${_excl[@]}" && continue
    _has_env_overlay "$chart" || { warn "$chart: no values-${ENV_NAME}.yaml overlay — skipping"; continue; }

    local ns
    ns="$(_get_env_namespace "$chart")"
    [[ -n "$FILTER_NS" && "$ns" != "$FILTER_NS" ]] && continue

    local json
    json="$(_get_helm_history "$chart" "$ns")"
    local count
    count=$(echo "$json" | jq 'length')

    if (( count < 2 )); then
      warn "$chart: only ${count} revision(s) — nothing to rollback to"
      continue
    fi

    local revision
    if revision=$(_select_revision "$chart" "$ns"); then
      local tier
      tier="$(_get_tier_for_chart "$chart")"
      local date
      date=$(echo "$json" | jq -r ".[] | select(.revision == $revision) | .updated" | sed 's/\.[0-9]* / /' | cut -c1-19)
      local current_rev
      current_rev="$(_get_current_revision "$json")"
      _add_to_plan "$chart" "$ns" "$revision" "$tier" "$date" "$current_rev"
    fi
  done

  if (( ${#PLAN_CHARTS[@]} == 0 )); then
    info "No charts selected for rollback."
    exit 0
  fi

  _display_rollback_plan

  local confirm_result=0
  _confirm_plan || confirm_result=$?
  if (( confirm_result == 2 )); then
    _edit_rollback_plan || { echo "Aborted."; exit 0; }
  elif (( confirm_result != 0 )); then
    echo "Aborted."
    exit 0
  fi

  _execute_rollback
}

# =============================================================================
# Mode 2: auto-detect (no options)
# =============================================================================
_mode_auto() {
  step "Scanning for unhealthy pods and recent deploys..."

  local all_charts
  mapfile -t all_charts < <(_get_all_known_charts)

  local DETECT_CHARTS=()
  local DETECT_REASONS=()
  local DETECT_AGO=()

  local now_epoch
  now_epoch=$(date +%s)

  for chart in "${all_charts[@]}"; do
    local ns
    ns="$(_get_env_namespace "$chart")"

    local reason=""
    local ago=""

    # Check pod health
    if _check_pod_health "$chart" "$ns"; then
      reason="UNHEALTHY"
    fi

    # Check recent deploy (last 1 hour)
    local json
    json="$(_get_helm_history "$chart" "$ns")"
    local count
    count=$(echo "$json" | jq 'length')
    if (( count > 0 )); then
      local last_updated
      last_updated=$(echo "$json" | jq -r 'last | .updated' | sed 's/\.[0-9]* / /' | cut -c1-19)
      local last_epoch
      last_epoch=$(_parse_helm_date "$last_updated")
      if (( last_epoch > 0 )); then
        local diff_secs=$(( now_epoch - last_epoch ))
        if (( diff_secs < 3600 )); then
          local mins=$(( diff_secs / 60 ))
          ago="${mins}m ago"
          [[ -z "$reason" ]] && reason="recent deploy"
        fi
      fi
    fi

    if [[ -n "$reason" ]]; then
      DETECT_CHARTS+=("$chart")
      DETECT_REASONS+=("$reason")
      DETECT_AGO+=("$ago")
    fi
  done

  if (( ${#DETECT_CHARTS[@]} == 0 )); then
    ok "All charts look healthy and no recent deploys detected."
    exit 0
  fi

  echo ""
  printf "  %-4s %-30s %-18s %s\n" "#" "CHART" "STATUS" "LAST DEPLOYED"
  printf "  %-4s %-30s %-18s %s\n" "──" "─────" "──────" "─────────────"
  for i in "${!DETECT_CHARTS[@]}"; do
    local status_display="${DETECT_REASONS[$i]}"
    [[ "$status_display" == "UNHEALTHY" ]] && status_display="${RED}!! UNHEALTHY${NC}"
    printf "  %-4s %-30s %-18b %s\n" "$((i+1)))" "${DETECT_CHARTS[$i]}" "$status_display" "${DETECT_AGO[$i]}"
  done
  echo ""
  echo "  Select charts to rollback (space-separated numbers, 'a' for all, Enter to cancel):"
  read -r -p "  > " selection

  [[ -z "$selection" ]] && { echo "Aborted."; exit 0; }

  local selected_charts=()
  if [[ "$selection" == "a" ]]; then
    selected_charts=("${DETECT_CHARTS[@]}")
  else
    for num in $selection; do
      if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#DETECT_CHARTS[@]} )); then
        selected_charts+=("${DETECT_CHARTS[$((num-1))]}")
      fi
    done
  fi

  if (( ${#selected_charts[@]} == 0 )); then
    echo "No valid selection."
    exit 0
  fi

  # Enter revision selection for each
  for chart in "${selected_charts[@]}"; do
    local ns
    ns="$(_get_env_namespace "$chart")"
    local json
    json="$(_get_helm_history "$chart" "$ns")"
    local count
    count=$(echo "$json" | jq 'length')

    if (( count < 2 )); then
      warn "$chart: only ${count} revision(s) — skipping"
      continue
    fi

    local revision
    if revision=$(_select_revision "$chart" "$ns"); then
      local tier
      tier="$(_get_tier_for_chart "$chart")"
      local date
      date=$(echo "$json" | jq -r ".[] | select(.revision == $revision) | .updated" | sed 's/\.[0-9]* / /' | cut -c1-19)
      local current_rev
      current_rev="$(_get_current_revision "$json")"
      _add_to_plan "$chart" "$ns" "$revision" "$tier" "$date" "$current_rev"
    fi
  done

  if (( ${#PLAN_CHARTS[@]} == 0 )); then
    info "No charts selected for rollback."
    exit 0
  fi

  _display_rollback_plan

  local confirm_result=0
  _confirm_plan || confirm_result=$?
  if (( confirm_result == 2 )); then
    _edit_rollback_plan || { echo "Aborted."; exit 0; }
  elif (( confirm_result != 0 )); then
    echo "Aborted."
    exit 0
  fi

  _execute_rollback
}

# =============================================================================
# Mode 3: --back-to (time-based rollback)
# =============================================================================
_mode_back_to() {
  local duration_secs
  duration_secs="$(_parse_duration "$BACK_TO")"

  local now_epoch cutoff_epoch
  now_epoch=$(date +%s)
  cutoff_epoch=$(( now_epoch - duration_secs ))

  step "Finding deploys after $(date -r "$cutoff_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -d "@$cutoff_epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "cutoff")..."

  local all_charts
  mapfile -t all_charts < <(_get_all_known_charts)

  for chart in "${all_charts[@]}"; do
    local ns
    ns="$(_get_env_namespace "$chart")"
    local json
    json="$(_get_helm_history "$chart" "$ns")"
    local count
    count=$(echo "$json" | jq 'length')
    (( count < 2 )) && continue

    # Check if any revision was deployed after cutoff
    local has_post_cutoff=false
    local best_pre_cutoff_rev=""
    local best_pre_cutoff_date=""
    local current_rev=""
    current_rev="$(_get_current_revision "$json")"

    for (( i=0; i<count; i++ )); do
      local rev status updated_str updated_epoch
      rev=$(echo "$json" | jq -r ".[$i].revision")
      status=$(echo "$json" | jq -r ".[$i].status")
      updated_str=$(echo "$json" | jq -r ".[$i].updated" | sed 's/\.[0-9]* / /' | cut -c1-19)
      updated_epoch=$(_parse_helm_date "$updated_str")

      [[ "$status" != "deployed" && "$status" != "superseded" ]] && continue

      if (( updated_epoch > cutoff_epoch )); then
        has_post_cutoff=true
      else
        # Track the most recent pre-cutoff revision
        if [[ -z "$best_pre_cutoff_rev" ]]; then
          best_pre_cutoff_rev="$rev"
          best_pre_cutoff_date="$updated_str"
        else
          local best_epoch
          best_epoch=$(_parse_helm_date "$best_pre_cutoff_date")
          if (( updated_epoch > best_epoch )); then
            best_pre_cutoff_rev="$rev"
            best_pre_cutoff_date="$updated_str"
          fi
        fi
      fi
    done

    if $has_post_cutoff && [[ -n "$best_pre_cutoff_rev" ]]; then
      local tier
      tier="$(_get_tier_for_chart "$chart")"
      _add_to_plan "$chart" "$ns" "$best_pre_cutoff_rev" "$tier" "$best_pre_cutoff_date" "$current_rev"
    elif $has_post_cutoff; then
      warn "$chart was deployed after cutoff but has no safe pre-cutoff revision — skipping"
    fi
  done

  if (( ${#PLAN_CHARTS[@]} == 0 )); then
    ok "No charts were deployed after the cutoff. Nothing to rollback."
    exit 0
  fi

  _display_rollback_plan

  local confirm_result=0
  _confirm_plan || confirm_result=$?
  if (( confirm_result == 2 )); then
    _edit_rollback_plan || { echo "Aborted."; exit 0; }
  elif (( confirm_result != 0 )); then
    echo "Aborted."
    exit 0
  fi

  _execute_rollback
}

# =============================================================================
# Mode dispatch
# =============================================================================
if [[ -n "$INCLUDE_LIST" ]]; then
  _mode_include
elif [[ -n "$BACK_TO" ]]; then
  _mode_back_to
else
  _mode_auto
fi
